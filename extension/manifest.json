{
  "manifest_version": 3,
  "name": "Cyber Shield - ML Scam Detector",
  "version": "3.0",
  "description": "AI-powered scam detection that automatically checks all messages and emails in real-time",
  
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  
  "host_permissions": [
    "*://*.whatsapp.com/*",
    "*://*.instagram.com/*",
    "*://*.mail.google.com/*",
    "*://mail.google.com/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cyber Shield - ML Detector"
  },
  
  "content_scripts": [
    {
      "matches": [
        "*://*.whatsapp.com/*",
        "*://*.instagram.com/*",
        "*://*.mail.google.com/*",
        "*://mail.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}